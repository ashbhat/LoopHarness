# ─────────────────────────────────────────────────────────────────────
# LoopHarness — environment variable template
# Copy to `.env` (gitignored) and fill in real values for local tooling.
#
# NOTE: The iOS/macOS app itself does NOT read this file. The app uses a
# "bring your own keys" model — keys are entered in-app (Settings →
# Integrations) and stored in the system Keychain (see KeyStore.swift).
# This file is only for the Python helper scripts in scripts/ and for
# optionally generating Secrets.xcconfig (see Secrets.xcconfig.example).
# ─────────────────────────────────────────────────────────────────────

# Speech-to-text (Deepgram)
DEEPGRAM_API_KEY=

# Text-to-speech (ElevenLabs)
ELEVEN_LABS_KEY=

# Web search (Exa)
EXA_API_KEY=

# LLM (OpenAI)
OPENAI_API_KEY=

# Cursor API (optional)
CURSOR_API_KEY=

# Obsidian relay (self-hosted)
OBSIDIAN_API_KEY=
OBSIDIAN_BASE_URL=https://your-domain.ngrok-free.dev

# Notion (used by scripts/NotionNoteManager.py)
NOTION_TOKEN=
NOTION_PARENT_PAGE_ID=
